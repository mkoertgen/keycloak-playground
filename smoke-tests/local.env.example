# Local environment overrides (NOT committed to git)
# Copy this file to local.env and add your test credentials

# Example overrides:
# LOG_LEVEL=DEBUG                    # Uncomment for verbose logging (DEBUG, INFO, WARNING, ERROR)
# TIMEOUT=10                         # HTTP request timeout for non-browser tests (in seconds)

# Playwright configuration (nested with __ delimiter)
# PLAYWRIGHT__HEADFUL=true           # Show browser UI instead of headless mode
# PLAYWRIGHT__SLOWMO=500             # Slow down operations by N milliseconds (useful for watching tests)
# PLAYWRIGHT__TRACE=on               # Trace recording mode: on, off, on-first-retry, retain-on-failure

# Keycloak configuration (nested with __ delimiter)
# KEYCLOAK__URL=http://localhost:8080
# KEYCLOAK__REALM=demo
# KEYCLOAK__USER=alice@democorp.com
# KEYCLOAK__PASSWORD=Password123!
# KEYCLOAK__OTP_SECRET=BASE32_ENCODED_SECRET_FOR_KEYCLOAK  # If testing 2FA
