# Keycloak Configuration
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=demo

# GitLab Configuration (optional, only needed for GitLab integration)
GITLAB_URL=http://localhost:8929
GITLAB_ADMIN_TOKEN=your-gitlab-admin-token

# GitLab Webhook (optional, only needed for webhook server)
# Generate with: openssl rand -hex 32
GITLAB_WEBHOOK_SECRET=your-webhook-secret-here

# API Server Configuration (optional, for webhook server)
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Group Sync Scheduler
# Cron expression: "minute hour day month day_of_week"
# Examples:
#   "* * * * *"     - Every minute (demo/testing)
#   "*/5 * * * *"   - Every 5 minutes
#   "*/10 * * * *"  - Every 10 minutes (recommended for production)
#   "*/30 * * * *"  - Every 30 minutes
#   "0 * * * *"     - Every hour
GROUP_SYNC_CRON=* * * * *
GROUP_SYNC_ENABLED=true
