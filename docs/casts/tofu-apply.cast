[0.427023, "o", "\r\n\u001b[0m\u001b[1mInitializing provider plugins...\u001b[0m\r\n- terraform.io/builtin/terraform is built in to OpenTofu\r\n- Finding keycloak/keycloak versions matching \"~> 5.6.0\"...\r\n"]
