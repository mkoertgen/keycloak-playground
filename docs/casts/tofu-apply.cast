[4.474289, "o", "\r\n\u001b[1m  # keycloak_realm.demo\u001b[0m has been deleted\r\n\u001b[0m  \u001b[31m-\u001b[0m\u001b[0m resource \"keycloak_realm\" \"demo\" {\r\n      \u001b[31m-\u001b[0m\u001b[0m id                                       = \"demo\" \u001b[90m-> null\u001b[0m\u001b[0m\r\n        \u001b[90m# (49 unchanged attributes hidden)\u001b[0m\u001b[0m\r\n\r\n        \u001b[90m# (5 unchanged blocks hidden)\u001b[0m\u001b[0m\r\n    }\r\n\r\n\u001b[1m  # keycloak_role.minimal_role\u001b[0m has been deleted\r\n\u001b[0m  \u001b[31m-\u001b[0m\u001b[0m resource \"keycloak_role\" \"minimal_role\" {\r\n        id              = \"b7e5ff85-9583-4bea-a19e-847816fb3a90\"\r\n      \u001b[31m-\u001b[0m\u001b[0m name            = \"minimal-role\" \u001b[90m-> null\u001b[0m\u001b[0m\r\n        \u001b[90m# (5 unchanged attributes hidden)\u001b[0m\u001b[0m\r\n    }\r\n\r\n\r\nUnless you have made equivalent changes to your configuration, or ignored the relevant attributes using ignore_changes,\r\nthe following plan may include actions to undo or respond to these changes.\r\n"]
