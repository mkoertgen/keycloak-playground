[4.475076, "o", "\r\n\u001b[1m  # keycloak_authentication_execution.otp_form[\"master\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_authentication_execution\" \"otp_form\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m authenticator     = \"auth-otp-form\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id                = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m parent_flow_alias = \"browser-with-otp-conditional\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id          = \"master\"\r\n      \u001b[32m+\u001b[0m\u001b[0m requirement       = \"ALTERNATIVE\"\r\n    }\r\n\r\n\u001b[1m  # keycloak_authentication_execution.otp_user_configured[\"demo\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_authentication_execution\" \"otp_user_configured\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m authenticator     = \"conditional-user-configured\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id                = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m parent_flow_alias = \"browser-with-otp-conditional\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id          = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m requirement       = \"REQUIRED\"\r\n    }\r\n\r\n\u001b[1m  # keycloak_authentication_execution.otp_user_configured[\"master\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_authentication_execution\" \"otp_user_configured\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m authenticator     = \"conditional-user-configured\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id                = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m parent_flow_alias = \"browser-with-otp-conditional\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id          = \"master\"\r\n      \u001b[32m+\u001b[0m\u001b[0m requirement       = \"REQUIRED\"\r\n    }\r\n\r\n\u001b[1m  # keycloak_authentication_execution.username_password[\"demo\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_authentication_execution\" \"username_password\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m authenticator     = \"auth-username-password-form\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id                = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m parent_flow_alias = \"browser-with-otp-forms\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id          = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m requirement       = \"REQUIRED\"\r\n    }\r\n\r\n\u001b[1m  # keycloak_authentication_execution.username_password[\"master\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_authentication_execution\" \"username_password\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m authenticator     = \"auth-username-password-form\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id                = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m parent_flow_alias = \"browser-with-otp-forms\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id          = \"master\"\r\n      \u001b[32m+\u001b[0m\u001b[0m requirement       = \"REQUIRED\"\r\n    }\r\n"]
[4.475342, "o", "\r\n\u001b[1m  # keycloak_authentication_execution.webauthn[\"demo\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_authentication_execution\" \"webauthn\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m authenticator     = \"webauthn-authenticator\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id                = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m parent_flow_alias = \"browser-with-otp-conditional\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id          = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m requirement       = \"ALTERNATIVE\"\r\n    }\r\n\r\n\u001b[1m  # keycloak_authentication_execution.webauthn[\"master\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_authentication_execution\" \"webauthn\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m authenticator     = \"webauthn-authenticator\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id                = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m parent_flow_alias = \"browser-with-otp-conditional\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id          = \"master\"\r\n      \u001b[32m+\u001b[0m\u001b[0m requirement       = \"ALTERNATIVE\"\r\n    }\r\n\r\n\u001b[1m  # keycloak_authentication_flow.browser_otp[\"demo\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_authentication_flow\" \"browser_otp\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m alias       = \"browser-with-otp\"\r\n      \u001b[32m+\u001b[0m\u001b[0m description = \"Browser flow with conditional 2FA (OTP or WebAuthn when configured)\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id          = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m provider_id = \"basic-flow\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id    = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # keycloak_authentication_flow.browser_otp[\"master\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_authentication_flow\" \"browser_otp\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m alias       = \"browser-with-otp\"\r\n      \u001b[32m+\u001b[0m\u001b[0m description = \"Browser flow with conditional 2FA (OTP or WebAuthn when configured)\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id          = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m provider_id = \"basic-flow\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id    = \"master\"\r\n    }\r\n\r\n\u001b[1m  # keycloak_authentication_subflow.conditional_otp[\"demo\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_authentication_subflow\" \"conditional_otp\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m alias             = \"browser-with-otp-conditional\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id                = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m parent_flow_alias = \"browser-with-otp-forms\"\r\n      \u001b[32m+\u001b[0m\u001b[0m provider_id       = \"basic-flow\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id          = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m requirement       = \"CONDITIONAL\"\r\n    }\r\n"]
[4.475479, "o", "\r\n\u001b[1m  # keycloak_authentication_subflow.conditional_otp[\"master\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_authentication_subflow\" \"conditional_otp\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m alias             = \"browser-with-otp-conditional\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id                = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m parent_flow_alias = \"browser-with-otp-forms\"\r\n      \u001b[32m+\u001b[0m\u001b[0m provider_id       = \"basic-flow\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id          = \"master\"\r\n      \u001b[32m+\u001b[0m\u001b[0m requirement       = \"CONDITIONAL\"\r\n    }\r\n\r\n\u001b[1m  # keycloak_authentication_subflow.forms[\"demo\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_authentication_subflow\" \"forms\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m alias             = \"browser-with-otp-forms\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id                = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m parent_flow_alias = \"browser-with-otp\"\r\n      \u001b[32m+\u001b[0m\u001b[0m provider_id       = \"basic-flow\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id          = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m requirement       = \"ALTERNATIVE\"\r\n    }\r\n\r\n\u001b[1m  # keycloak_authentication_subflow.forms[\"master\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_authentication_subflow\" \"forms\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m alias             = \"browser-with-otp-forms\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id                = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m parent_flow_alias = \"browser-with-otp\"\r\n      \u001b[32m+\u001b[0m\u001b[0m provider_id       = \"basic-flow\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id          = \"master\"\r\n      \u001b[32m+\u001b[0m\u001b[0m requirement       = \"ALTERNATIVE\"\r\n    }\r\n\r\n\u001b[1m  # keycloak_default_roles.default\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_default_roles\" \"default\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m default_roles = [\r\n          \u001b[32m+\u001b[0m\u001b[0m \"account/manage-account\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"account/view-profile\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"minimal-role\",\r\n        ]\r\n      \u001b[32m+\u001b[0m\u001b[0m id            = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id      = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # keycloak_group.groups[\"admins\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_group\" \"groups\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m id       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m name     = \"admins\"\r\n      \u001b[32m+\u001b[0m\u001b[0m path     = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # keycloak_group.groups[\"demo-team-alpha\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_group\" \"groups\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m id       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m name     = \"demo-team-alpha\"\r\n      \u001b[32m+\u001b[0m\u001b[0m path     = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id = (known after apply)\r\n    }\r\n"]
[4.475688, "o", "\r\n\u001b[1m  # keycloak_group.groups[\"demo-team-beta\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_group\" \"groups\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m id       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m name     = \"demo-team-beta\"\r\n      \u001b[32m+\u001b[0m\u001b[0m path     = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # keycloak_group.groups[\"developers\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_group\" \"groups\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m id       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m name     = \"developers\"\r\n      \u001b[32m+\u001b[0m\u001b[0m path     = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # keycloak_group.groups[\"external\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_group\" \"groups\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m id       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m name     = \"external\"\r\n      \u001b[32m+\u001b[0m\u001b[0m path     = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id = (known after apply)\r\n    }\r\n"]
[4.475802, "o", "\r\n\u001b[1m  # keycloak_group_memberships.memberships[\"admins\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_group_memberships\" \"memberships\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m group_id = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m id       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m members  = [\r\n          \u001b[32m+\u001b[0m\u001b[0m \"alice\",\r\n        ]\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # keycloak_group_memberships.memberships[\"demo-team-alpha\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_group_memberships\" \"memberships\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m group_id = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m id       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m members  = [\r\n          \u001b[32m+\u001b[0m\u001b[0m \"alice\",\r\n        ]\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # keycloak_group_memberships.memberships[\"demo-team-beta\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_group_memberships\" \"memberships\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m group_id = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m id       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m members  = [\r\n          \u001b[32m+\u001b[0m\u001b[0m \"bob\",\r\n        ]\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id = (known after apply)\r\n    }\r\n"]
[4.475954, "o", "\r\n\u001b[1m  # keycloak_group_memberships.memberships[\"developers\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_group_memberships\" \"memberships\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m group_id = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m id       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m members  = [\r\n          \u001b[32m+\u001b[0m\u001b[0m \"bob\",\r\n        ]\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # keycloak_group_memberships.memberships[\"external\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_group_memberships\" \"memberships\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m group_id = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m id       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id = (known after apply)\r\n    }\r\n"]
[4.476098, "o", "\r\n\u001b[1m  # keycloak_openid_client.oidc_clients[\"demo-app\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_openid_client\" \"oidc_clients\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m access_token_lifespan                     = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m access_type                               = \"CONFIDENTIAL\"\r\n      \u001b[32m+\u001b[0m\u001b[0m admin_url                                 = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m always_display_in_console                 = false\r\n      \u001b[32m+\u001b[0m\u001b[0m backchannel_logout_session_required       = true\r\n      \u001b[32m+\u001b[0m\u001b[0m backchannel_logout_url                    = \"http://localhost:3000/backchannel-logout\"\r\n      \u001b[32m+\u001b[0m\u001b[0m base_url                                  = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m client_authenticator_type                 = \"client-secret\"\r\n      \u001b[32m+\u001b[0m\u001b[0m client_id                                 = \"demo-app\"\r\n      \u001b[32m+\u001b[0m\u001b[0m client_offline_session_idle_timeout       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m client_offline_session_max_lifespan       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m client_secret                             = (sensitive value)\r\n      \u001b[32m+\u001b[0m\u001b[0m client_secret_wo                          = (write-only attribute)\r\n      \u001b[32m+\u001b[0m\u001b[0m client_session_idle_timeout               = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m client_session_max_lifespan               = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m consent_required                          = false\r\n      \u001b[32m+\u001b[0m\u001b[0m consent_screen_text                       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m direct_access_grants_enabled              = true\r\n      \u001b[32m+\u001b[0m\u001b[0m display_on_consent_screen                 = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m enabled                                   = true\r\n      \u001b[32m+\u001b[0m\u001b[0m exclude_issuer_from_auth_response         = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m exclude_session_state_from_auth_response  = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m frontchannel_logout_enabled               = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m full_scope_allowed                        = true\r\n      \u001b[32m+\u001b[0m\u001b[0m id                                        = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m implicit_flow_enabled                     = false\r\n      \u001b[32m+\u001b[0m\u001b[0m import                                    = false\r\n      \u001b[32m+\u001b[0m\u001b[0m name                                      = \"Demo App\"\r\n      \u001b[32m+\u001b[0m\u001b[0m oauth2_device_authorization_grant_enabled = false\r\n      \u001b[32m+\u001b[0m\u001b[0m pkce_code_challenge_method                = \"S256\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id                                  = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m require_dpop_bound_tokens                 = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m resource_server_id                        = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m root_url                                  = \"http://localhost:3000\"\r\n      \u001b[32m+\u001b[0m\u001b[0m service_account_user_id                   = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m service_accounts_enabled                  = true\r\n      \u001b[32m+\u001b[0m\u001b[0m standard_flow_enabled                     = true\r\n      \u001b[32m+\u001b[0m\u001b[0m standard_token_exchange_enabled           = false\r\n      \u001b[32m+\u001b[0m\u001b[0m use_refresh_tokens                        = true\r\n      \u001b[32m+\u001b[0m\u001b[0m use_refresh_tokens_client_credentials     = false\r\n      \u001b[32m+\u001b[0m\u001b[0m valid_post_logout_redirect_uris           = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m valid_redirect_uris                       = [\r\n          \u001b[32m+\u001b[0m\u001b[0m \"http://localhost:3000/*\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"http://localhost:3000/callback\",\r\n        ]\r\n      \u001b[32m+\u001b[0m\u001b[0m web_origins                               = [\r\n          \u001b[32m+\u001b[0m\u001b[0m \"+\",\r\n        ]\r\n    }\r\n"]
[4.476264, "o", "\r\n\u001b[1m  # keycloak_openid_client_default_scopes.oidc_clients[\"demo-app\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_openid_client_default_scopes\" \"oidc_clients\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m client_id      = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m default_scopes = [\r\n          \u001b[32m+\u001b[0m\u001b[0m \"email\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"groups\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"profile\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"roles\",\r\n        ]\r\n      \u001b[32m+\u001b[0m\u001b[0m id             = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id       = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # keycloak_openid_client_optional_scopes.oidc_clients[\"demo-app\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_openid_client_optional_scopes\" \"oidc_clients\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m client_id       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m id              = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m optional_scopes = [\r\n          \u001b[32m+\u001b[0m\u001b[0m \"address\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"groups_fullpath\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"microprofile-jwt\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"offline_access\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"phone\",\r\n        ]\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id        = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # keycloak_openid_client_scope.groups\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_openid_client_scope\" \"groups\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m consent_screen_text    = \"Group membership information\"\r\n      \u001b[32m+\u001b[0m\u001b[0m description            = \"Group membership (simple names)\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id                     = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m include_in_token_scope = true\r\n      \u001b[32m+\u001b[0m\u001b[0m name                   = \"groups\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id               = (known after apply)\r\n    }\r\n"]
[4.476431, "o", "\r\n\u001b[1m  # keycloak_openid_client_scope.groups_fullpath\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_openid_client_scope\" \"groups_fullpath\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m consent_screen_text    = \"Group membership with full paths\"\r\n      \u001b[32m+\u001b[0m\u001b[0m description            = \"Group membership (full paths)\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id                     = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m include_in_token_scope = true\r\n      \u001b[32m+\u001b[0m\u001b[0m name                   = \"groups_fullpath\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id               = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # keycloak_openid_group_membership_protocol_mapper.groups\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_openid_group_membership_protocol_mapper\" \"groups\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m add_to_access_token = true\r\n      \u001b[32m+\u001b[0m\u001b[0m add_to_id_token     = true\r\n      \u001b[32m+\u001b[0m\u001b[0m add_to_userinfo     = true\r\n      \u001b[32m+\u001b[0m\u001b[0m claim_name          = \"groups\"\r\n      \u001b[32m+\u001b[0m\u001b[0m client_scope_id     = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m full_path           = false\r\n      \u001b[32m+\u001b[0m\u001b[0m id                  = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m name                = \"groups\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id            = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # keycloak_openid_group_membership_protocol_mapper.groups_fullpath\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_openid_group_membership_protocol_mapper\" \"groups_fullpath\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m add_to_access_token = true\r\n      \u001b[32m+\u001b[0m\u001b[0m add_to_id_token     = true\r\n      \u001b[32m+\u001b[0m\u001b[0m add_to_userinfo     = true\r\n      \u001b[32m+\u001b[0m\u001b[0m claim_name          = \"groups_fullpath\"\r\n      \u001b[32m+\u001b[0m\u001b[0m client_scope_id     = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m full_path           = true\r\n      \u001b[32m+\u001b[0m\u001b[0m id                  = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m name                = \"groups_fullpath\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id            = (known after apply)\r\n    }\r\n"]
[4.476585, "o", "\r\n\u001b[1m  # keycloak_organization.organizations[\"acme-inc\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_organization\" \"organizations\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m alias       = \"acme-inc\"\r\n      \u001b[32m+\u001b[0m\u001b[0m attributes  = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m description = \"Acme organization for OIDC demos\"\r\n      \u001b[32m+\u001b[0m\u001b[0m enabled     = true\r\n      \u001b[32m+\u001b[0m\u001b[0m id          = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m name        = \"Acme Inc\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm       = (known after apply)\r\n\r\n      \u001b[32m+\u001b[0m\u001b[0m domain {\r\n          \u001b[32m+\u001b[0m\u001b[0m name     = \"acme.example\"\r\n          \u001b[32m+\u001b[0m\u001b[0m verified = true\r\n        }\r\n    }\r\n\r\n\u001b[1m  # keycloak_organization.organizations[\"demo-corp\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_organization\" \"organizations\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m alias       = \"demo-corp\"\r\n      \u001b[32m+\u001b[0m\u001b[0m attributes  = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m description = \"Demo organization for testing\"\r\n      \u001b[32m+\u001b[0m\u001b[0m enabled     = true\r\n      \u001b[32m+\u001b[0m\u001b[0m id          = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m name        = \"Demo Corp\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm       = (known after apply)\r\n\r\n      \u001b[32m+\u001b[0m\u001b[0m domain {\r\n          \u001b[32m+\u001b[0m\u001b[0m name     = \"democorp.com\"\r\n          \u001b[32m+\u001b[0m\u001b[0m verified = true\r\n        }\r\n    }\r\n\r\n\u001b[1m  # keycloak_organization.organizations[\"test-industries\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_organization\" \"organizations\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m alias       = \"test-industries\"\r\n      \u001b[32m+\u001b[0m\u001b[0m attributes  = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m description = \"Test organization for local development\"\r\n      \u001b[32m+\u001b[0m\u001b[0m enabled     = true\r\n      \u001b[32m+\u001b[0m\u001b[0m id          = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m name        = \"Test Industries\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm       = (known after apply)\r\n\r\n      \u001b[32m+\u001b[0m\u001b[0m domain {\r\n          \u001b[32m+\u001b[0m\u001b[0m name     = \"test.local\"\r\n          \u001b[32m+\u001b[0m\u001b[0m verified = true\r\n        }\r\n    }\r\n"]
[4.47686, "o", "\r\n\u001b[1m  # keycloak_realm.demo\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_realm\" \"demo\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m access_code_lifespan                     = \"1m\"\r\n      \u001b[32m+\u001b[0m\u001b[0m access_code_lifespan_login               = \"1m\"\r\n      \u001b[32m+\u001b[0m\u001b[0m access_code_lifespan_user_action         = \"1m\"\r\n      \u001b[32m+\u001b[0m\u001b[0m access_token_lifespan                    = \"5m\"\r\n      \u001b[32m+\u001b[0m\u001b[0m access_token_lifespan_for_implicit_flow  = \"15m\"\r\n      \u001b[32m+\u001b[0m\u001b[0m account_theme                            = \"keycloak-theme\"\r\n      \u001b[32m+\u001b[0m\u001b[0m action_token_generated_by_admin_lifespan = \"12h\"\r\n      \u001b[32m+\u001b[0m\u001b[0m action_token_generated_by_user_lifespan  = \"30m\"\r\n      \u001b[32m+\u001b[0m\u001b[0m attributes                               = {\r\n          \u001b[32m+\u001b[0m\u001b[0m \"actionTokenGeneratedByUserLifespan.execute-actions\"              = \"1800\"\r\n          \u001b[32m+\u001b[0m\u001b[0m \"actionTokenGeneratedByUserLifespan.idp-verify-account-via-email\" = \"3600\"\r\n          \u001b[32m+\u001b[0m\u001b[0m \"actionTokenGeneratedByUserLifespan.reset-credentials\"            = \"600\"\r\n          \u001b[32m+\u001b[0m\u001b[0m \"actionTokenGeneratedByUserLifespan.verify-email\"                 = \"86400\"\r\n          \u001b[32m+\u001b[0m\u001b[0m \"adminEventsExpiration\"                                           = \"604800\"\r\n          \u001b[32m+\u001b[0m\u001b[0m \"clientOfflineSessionIdleTimeout\"                                 = \"3600\"\r\n          \u001b[32m+\u001b[0m\u001b[0m \"clientOfflineSessionMaxLifespan\"                                 = \"86400\"\r\n        }\r\n      \u001b[32m+\u001b[0m\u001b[0m browser_flow                             = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m client_authentication_flow               = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m client_session_idle_timeout              = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m client_session_max_lifespan              = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m default_signature_algorithm              = \"RS256\"\r\n      \u001b[32m+\u001b[0m\u001b[0m direct_grant_flow                        = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m display_name                             = \"Demo Realm\"\r\n      \u001b[32m+\u001b[0m\u001b[0m display_name_html                        = \"<b>Demo</b> Realm\"\r\n      \u001b[32m+\u001b[0m\u001b[0m docker_authentication_flow               = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m duplicate_emails_allowed                 = false\r\n      \u001b[32m+\u001b[0m\u001b[0m edit_username_allowed                    = false\r\n      \u001b[32m+\u001b[0m\u001b[0m email_theme                              = \"keycloak-theme\"\r\n      \u001b[32m+\u001b[0m\u001b[0m enabled                                  = true\r\n      \u001b[32m+\u001b[0m\u001b[0m first_broker_login_flow                  = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m id                                       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m internal_id                              = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m login_theme                              = \"keycloak-theme\"\r\n      \u001b[32m+\u001b[0m\u001b[0m login_with_email_allowed                 = true\r\n      \u001b[32m+\u001b[0m\u001b[0m oauth2_device_code_lifespan              = \"10m\"\r\n      \u001b[32m+\u001b[0m\u001b[0m oauth2_device_polling_interval           = 5\r\n      \u001b[32m+\u001b[0m\u001b[0m offline_session_idle_timeout             = \"1h\"\r\n      \u001b[32m+\u001b[0m\u001b[0m offline_session_max_lifespan             = \"24h\"\r\n      \u001b[32m+\u001b[0m\u001b[0m offline_session_max_lifespan_enabled     = true\r\n      \u001b[32m+\u001b[0m\u001b[0m organizations_enabled                    = true\r\n      \u001b[32m+\u001b[0m\u001b[0m password_policy                          = \"upperCase(1) and length(12) and notUsername(undefined) and passwordHistory(5) and lowerCase(1) and digits(1)\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm                                    = \"demo\"\r\n      \u001b[32m+\u001b[0m\u001b[0m refresh_token_max_reuse                  = 0\r\n      \u001b[32m+\u001b[0m\u001b[0m registration_allowed                     = false\r\n"]
[4.477002, "o", "      \u001b[32m+\u001b[0m\u001b[0m registration_email_as_username           = false\r\n      \u001b[32m+\u001b[0m\u001b[0m registration_flow                        = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m remember_me                              = true\r\n      \u001b[32m+\u001b[0m\u001b[0m reset_credentials_flow                   = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m reset_password_allowed                   = true\r\n      \u001b[32m+\u001b[0m\u001b[0m revoke_refresh_token                     = false\r\n      \u001b[32m+\u001b[0m\u001b[0m ssl_required                             = \"none\"\r\n      \u001b[32m+\u001b[0m\u001b[0m sso_session_idle_timeout                 = \"2h\"\r\n      \u001b[32m+\u001b[0m\u001b[0m sso_session_idle_timeout_remember_me     = \"4h\"\r\n      \u001b[32m+\u001b[0m\u001b[0m sso_session_max_lifespan                 = \"10h\"\r\n      \u001b[32m+\u001b[0m\u001b[0m sso_session_max_lifespan_remember_me     = \"24h\"\r\n      \u001b[32m+\u001b[0m\u001b[0m terraform_deletion_protection            = false\r\n      \u001b[32m+\u001b[0m\u001b[0m user_managed_access                      = false\r\n      \u001b[32m+\u001b[0m\u001b[0m verify_email                             = false\r\n\r\n      \u001b[32m+\u001b[0m\u001b[0m internationalization {\r\n          \u001b[32m+\u001b[0m\u001b[0m default_locale    = \"en\"\r\n          \u001b[32m+\u001b[0m\u001b[0m supported_locales = [\r\n              \u001b[32m+\u001b[0m\u001b[0m \"de\",\r\n              \u001b[32m+\u001b[0m\u001b[0m \"en\",\r\n            ]\r\n        }\r\n\r\n      \u001b[32m+\u001b[0m\u001b[0m otp_policy {\r\n          \u001b[32m+\u001b[0m\u001b[0m algorithm         = \"HmacSHA256\"\r\n          \u001b[32m+\u001b[0m\u001b[0m digits            = 6\r\n          \u001b[32m+\u001b[0m\u001b[0m initial_counter   = 2\r\n          \u001b[32m+\u001b[0m\u001b[0m look_ahead_window = 1\r\n          \u001b[32m+\u001b[0m\u001b[0m period            = 30\r\n          \u001b[32m+\u001b[0m\u001b[0m type              = \"totp\"\r\n        }\r\n\r\n      \u001b[32m+\u001b[0m\u001b[0m security_defenses {\r\n          \u001b[32m+\u001b[0m\u001b[0m brute_force_detection {\r\n              \u001b[32m+\u001b[0m\u001b[0m failure_reset_time_seconds       = 43200\r\n              \u001b[32m+\u001b[0m\u001b[0m max_failure_wait_seconds         = 900\r\n              \u001b[32m+\u001b[0m\u001b[0m max_login_failures               = 10\r\n              \u001b[32m+\u001b[0m\u001b[0m max_temporary_lockouts           = 0\r\n              \u001b[32m+\u001b[0m\u001b[0m minimum_quick_login_wait_seconds = 60\r\n              \u001b[32m+\u001b[0m\u001b[0m permanent_lockout                = false\r\n              \u001b[32m+\u001b[0m\u001b[0m quick_login_check_milli_seconds  = 1000\r\n              \u001b[32m+\u001b[0m\u001b[0m wait_increment_seconds           = 60\r\n            }\r\n          \u001b[32m+\u001b[0m\u001b[0m headers {\r\n              \u001b[32m+\u001b[0m\u001b[0m content_security_policy   = \"frame-src 'self'; frame-ancestors 'self'; object-src 'none';\"\r\n              \u001b[32m+\u001b[0m\u001b[0m referrer_policy           = \"no-referrer\"\r\n              \u001b[32m+\u001b[0m\u001b[0m strict_transport_security = \"max-age=31536000; includeSubDomains\"\r\n              \u001b[32m+\u001b[0m\u001b[0m x_content_type_options    = \"nosniff\"\r\n              \u001b[32m+\u001b[0m\u001b[0m x_frame_options           = \"DENY\"\r\n              \u001b[32m+\u001b[0m\u001b[0m x_robots_tag              = \"none\"\r\n              \u001b[32m+\u001b[0m\u001b[0m x_xss_protection          = \"1; mode=block\"\r\n            }\r\n        }\r\n\r\n      \u001b[32m+\u001b[0m\u001b[0m web_authn_passwordless_policy (known after apply)\r\n\r\n      \u001b[32m+\u001b[0m\u001b[0m web_authn_policy {\r\n          \u001b[32m+\u001b[0m\u001b[0m attestation_conveyance_preference = \"not specified\"\r\n          \u001b[32m+\u001b[0m\u001b[0m authenticator_attachment          = \"not specified\"\r\n          \u001b[32m+\u001b[0m\u001b[0m avoid_same_authenticator_register = false\r\n          \u001b[32m+\u001b[0m\u001b[0m create_timeout                    = 0\r\n          \u001b[32m+\u001b[0m\u001b[0m relying_party_entity_name         = \"Demo Keycloak\"\r\n          \u001b[32m+\u001b[0m\u001b[0m relying_party_id                  = \"localhost\"\r\n          \u001b[32m+\u001b[0m\u001b[0m require_resident_key              = \"not specified\"\r\n          \u001b[32m+\u001b[0m\u001b[0m signature_algorithms              = [\r\n              \u001b[32m+\u001b[0m\u001b[0m \"ES256\",\r\n              \u001b[32m+\u001b[0m\u001b[0m \"RS256\",\r\n            ]\r\n          \u001b[32m+\u001b[0m\u001b[0m user_verification_requirement     = \"preferred\"\r\n        }\r\n    }\r\n"]
[4.477177, "o", "\r\n\u001b[1m  # keycloak_realm.master\u001b[0m will be updated in-place\r\n\u001b[0m  \u001b[33m~\u001b[0m\u001b[0m resource \"keycloak_realm\" \"master\" {\r\n      \u001b[31m-\u001b[0m\u001b[0m default_signature_algorithm              = \"RS256\" \u001b[90m-> null\u001b[0m\u001b[0m\r\n      \u001b[31m-\u001b[0m\u001b[0m display_name                             = \"Keycloak\" \u001b[90m-> null\u001b[0m\u001b[0m\r\n      \u001b[31m-\u001b[0m\u001b[0m display_name_html                        = \"<div class=\\\"kc-logo-text\\\"><span>Keycloak</span></div>\" \u001b[90m-> null\u001b[0m\u001b[0m\r\n        id                                       = \"master\"\r\n      \u001b[32m+\u001b[0m\u001b[0m password_policy                          = \"upperCase(1) and length(12) and notUsername(undefined) and passwordHistory(5) and lowerCase(1) and digits(1)\"\r\n        \u001b[90m# (46 unchanged attributes hidden)\u001b[0m\u001b[0m\r\n\r\n      \u001b[33m~\u001b[0m\u001b[0m security_defenses {\r\n          \u001b[32m+\u001b[0m\u001b[0m brute_force_detection {\r\n              \u001b[32m+\u001b[0m\u001b[0m failure_reset_time_seconds       = 43200\r\n              \u001b[32m+\u001b[0m\u001b[0m max_failure_wait_seconds         = 900\r\n              \u001b[32m+\u001b[0m\u001b[0m max_login_failures               = 5\r\n              \u001b[32m+\u001b[0m\u001b[0m max_temporary_lockouts           = 0\r\n              \u001b[32m+\u001b[0m\u001b[0m minimum_quick_login_wait_seconds = 60\r\n              \u001b[32m+\u001b[0m\u001b[0m permanent_lockout                = false\r\n              \u001b[32m+\u001b[0m\u001b[0m quick_login_check_milli_seconds  = 1000\r\n              \u001b[32m+\u001b[0m\u001b[0m wait_increment_seconds           = 60\r\n            }\r\n          \u001b[33m~\u001b[0m\u001b[0m headers {\r\n              \u001b[33m~\u001b[0m\u001b[0m x_frame_options           = \"SAMEORIGIN\" \u001b[33m->\u001b[0m\u001b[0m \"DENY\"\r\n              \u001b[32m+\u001b[0m\u001b[0m x_xss_protection          = \"1; mode=block\"\r\n                \u001b[90m# (5 unchanged attributes hidden)\u001b[0m\u001b[0m\r\n            }\r\n        }\r\n\r\n        \u001b[90m# (3 unchanged blocks hidden)\u001b[0m\u001b[0m\r\n    }\r\n\r\n\u001b[1m  # keycloak_realm_events.demo\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_realm_events\" \"demo\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m admin_events_details_enabled = true\r\n      \u001b[32m+\u001b[0m\u001b[0m admin_events_enabled         = true\r\n      \u001b[32m+\u001b[0m\u001b[0m enabled_event_types          = [\r\n          \u001b[32m+\u001b[0m\u001b[0m \"LOGIN\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"LOGIN_ERROR\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"LOGOUT\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"REGISTER\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"REMOVE_TOTP\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"UPDATE_PASSWORD\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"UPDATE_TOTP\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"VERIFY_EMAIL\",\r\n        ]\r\n      \u001b[32m+\u001b[0m\u001b[0m events_enabled               = true\r\n      \u001b[32m+\u001b[0m\u001b[0m events_expiration            = 604800\r\n      \u001b[32m+\u001b[0m\u001b[0m events_listeners             = [\r\n          \u001b[32m+\u001b[0m\u001b[0m \"jboss-logging\",\r\n        ]\r\n      \u001b[32m+\u001b[0m\u001b[0m id                           = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id                     = (known after apply)\r\n    }\r\n"]
[4.477318, "o", "\r\n"]
[4.477442, "o", "\u001b[1m  # keycloak_realm_events.demo_events\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_realm_events\" \"demo_events\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m admin_events_details_enabled = true\r\n      \u001b[32m+\u001b[0m\u001b[0m admin_events_enabled         = true\r\n      \u001b[32m+\u001b[0m\u001b[0m enabled_event_types          = [\r\n          \u001b[32m+\u001b[0m\u001b[0m \"CLIENT_LOGIN\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"CLIENT_LOGIN_ERROR\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"LOGIN\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"LOGIN_ERROR\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"LOGOUT\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"REGISTER\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"REGISTER_ERROR\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"REMOVE_TOTP\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"SEND_RESET_PASSWORD\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"SEND_VERIFY_EMAIL\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"UPDATE_EMAIL\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"UPDATE_PASSWORD\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"UPDATE_PASSWORD_ERROR\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"UPDATE_TOTP\",\r\n          \u001b[32m+\u001b[0m\u001b[0m \"VERIFY_EMAIL\",\r\n        ]\r\n      \u001b[32m+\u001b[0m\u001b[0m events_enabled               = true\r\n      \u001b[32m+\u001b[0m\u001b[0m events_expiration            = 604800\r\n      \u001b[32m+\u001b[0m\u001b[0m events_listeners             = [\r\n          \u001b[32m+\u001b[0m\u001b[0m \"jboss-logging\",\r\n        ]\r\n      \u001b[32m+\u001b[0m\u001b[0m id                           = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id                     = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # keycloak_realm_events.master\u001b[0m will be updated in-place\r\n\u001b[0m  \u001b[33m~\u001b[0m\u001b[0m resource \"keycloak_realm_events\" \"master\" {\r\n      \u001b[33m~\u001b[0m\u001b[0m admin_events_details_enabled = false \u001b[33m->\u001b[0m\u001b[0m true\r\n      \u001b[33m~\u001b[0m\u001b[0m admin_events_enabled         = false \u001b[33m->\u001b[0m\u001b[0m true\r\n        id                           = \"master\"\r\n        \u001b[90m# (4 unchanged attributes hidden)\u001b[0m\u001b[0m\r\n    }\r\n\r\n\u001b[1m  # keycloak_required_action.configure_totp[\"demo\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_required_action\" \"configure_totp\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m alias          = \"CONFIGURE_TOTP\"\r\n      \u001b[32m+\u001b[0m\u001b[0m default_action = true\r\n      \u001b[32m+\u001b[0m\u001b[0m enabled        = true\r\n      \u001b[32m+\u001b[0m\u001b[0m id             = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m name           = \"Configure OTP\"\r\n      \u001b[32m+\u001b[0m\u001b[0m priority       = 10\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id       = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # keycloak_required_action.configure_totp[\"master\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_required_action\" \"configure_totp\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m alias          = \"CONFIGURE_TOTP\"\r\n      \u001b[32m+\u001b[0m\u001b[0m default_action = true\r\n      \u001b[32m+\u001b[0m\u001b[0m enabled        = true\r\n      \u001b[32m+\u001b[0m\u001b[0m id             = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m name           = \"Configure OTP\"\r\n      \u001b[32m+\u001b[0m\u001b[0m priority       = 10\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id       = \"master\"\r\n    }\r\n\r\n\u001b[1m  # keycloak_role.minimal_role\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_role\" \"minimal_role\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m attributes      = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m composite_roles = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m description     = \"Role with minimal privileges for all users\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id              = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m import          = false\r\n      \u001b[32m+\u001b[0m\u001b[0m name            = \"minimal-role\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id        = (known after apply)\r\n    }\r\n"]
[4.477611, "o", "\r\n\u001b[1m  # keycloak_user.master_admin_users[\"admin-ops\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_user\" \"master_admin_users\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m email            = \"admin-ops@example.com\"\r\n      \u001b[32m+\u001b[0m\u001b[0m email_verified   = true\r\n      \u001b[32m+\u001b[0m\u001b[0m enabled          = true\r\n      \u001b[32m+\u001b[0m\u001b[0m first_name       = \"Ops\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id               = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m import           = false\r\n      \u001b[32m+\u001b[0m\u001b[0m last_name        = \"Admin\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id         = \"master\"\r\n      \u001b[32m+\u001b[0m\u001b[0m required_actions = [\r\n          \u001b[32m+\u001b[0m\u001b[0m \"CONFIGURE_TOTP\",\r\n        ]\r\n      \u001b[32m+\u001b[0m\u001b[0m username         = \"admin-ops\"\r\n\r\n      \u001b[32m+\u001b[0m\u001b[0m initial_password {\r\n          \u001b[32m+\u001b[0m\u001b[0m temporary = true\r\n          \u001b[32m+\u001b[0m\u001b[0m value     = (sensitive value)\r\n        }\r\n    }\r\n"]
[4.477756, "o", "\r\n\u001b[1m  # keycloak_user.test_users[\"alice\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_user\" \"test_users\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m email          = \"alice@democorp.com\"\r\n      \u001b[32m+\u001b[0m\u001b[0m email_verified = true\r\n      \u001b[32m+\u001b[0m\u001b[0m enabled        = true\r\n      \u001b[32m+\u001b[0m\u001b[0m first_name     = \"Alice\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id             = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m import         = false\r\n      \u001b[32m+\u001b[0m\u001b[0m last_name      = \"Smith\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m username       = \"alice\"\r\n\r\n      \u001b[32m+\u001b[0m\u001b[0m initial_password {\r\n          \u001b[32m+\u001b[0m\u001b[0m temporary = false\r\n          \u001b[32m+\u001b[0m\u001b[0m value     = (sensitive value)\r\n        }\r\n    }\r\n\r\n\u001b[1m  # keycloak_user.test_users[\"bob\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_user\" \"test_users\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m email          = \"bob@acme.example\"\r\n      \u001b[32m+\u001b[0m\u001b[0m email_verified = true\r\n      \u001b[32m+\u001b[0m\u001b[0m enabled        = true\r\n      \u001b[32m+\u001b[0m\u001b[0m first_name     = \"Bob\"\r\n      \u001b[32m+\u001b[0m\u001b[0m id             = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m import         = false\r\n      \u001b[32m+\u001b[0m\u001b[0m last_name      = \"Johnson\"\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m username       = \"bob\"\r\n\r\n      \u001b[32m+\u001b[0m\u001b[0m initial_password {\r\n          \u001b[32m+\u001b[0m\u001b[0m temporary = false\r\n          \u001b[32m+\u001b[0m\u001b[0m value     = (sensitive value)\r\n        }\r\n    }\r\n\r\n\u001b[1m  # keycloak_user_roles.master_admin_users[\"admin-ops\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"keycloak_user_roles\" \"master_admin_users\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m exhaustive = true\r\n      \u001b[32m+\u001b[0m\u001b[0m id         = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m realm_id   = \"master\"\r\n      \u001b[32m+\u001b[0m\u001b[0m role_ids   = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m user_id    = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # terraform_data.seed_totp[\"alice\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"terraform_data\" \"seed_totp\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m id               = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m triggers_replace = [\r\n          \u001b[32m+\u001b[0m\u001b[0m (known after apply),\r\n          \u001b[32m+\u001b[0m\u001b[0m \"ada0ad09c3cc229a6204eef826d61a8035e307fc648ee9ec8a592ab11260a868\",\r\n        ]\r\n    }\r\n"]
[4.477915, "o", "\r\n\u001b[1m  # terraform_data.seed_totp[\"bob\"]\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"terraform_data\" \"seed_totp\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m id               = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m triggers_replace = [\r\n          \u001b[32m+\u001b[0m\u001b[0m (known after apply),\r\n          \u001b[32m+\u001b[0m\u001b[0m \"0b9e41b0944238dac70abcbbd0326806dbf6f03995b2b28f41fafc9d174efe91\",\r\n        ]\r\n    }\r\n\r\n\u001b[1mPlan:\u001b[0m 57 to add, 2 to change, 0 to destroy.\r\n\u001b[0m\r\nChanges to Outputs:\r\n  \u001b[32m+\u001b[0m\u001b[0m groups              = {\r\n      \u001b[32m+\u001b[0m\u001b[0m admins          = {\r\n          \u001b[32m+\u001b[0m\u001b[0m id   = (known after apply)\r\n          \u001b[32m+\u001b[0m\u001b[0m path = (known after apply)\r\n        }\r\n      \u001b[32m+\u001b[0m\u001b[0m demo-team-alpha = {\r\n          \u001b[32m+\u001b[0m\u001b[0m id   = (known after apply)\r\n          \u001b[32m+\u001b[0m\u001b[0m path = (known after apply)\r\n        }\r\n      \u001b[32m+\u001b[0m\u001b[0m demo-team-beta  = {\r\n          \u001b[32m+\u001b[0m\u001b[0m id   = (known after apply)\r\n          \u001b[32m+\u001b[0m\u001b[0m path = (known after apply)\r\n        }\r\n      \u001b[32m+\u001b[0m\u001b[0m developers      = {\r\n          \u001b[32m+\u001b[0m\u001b[0m id   = (known after apply)\r\n          \u001b[32m+\u001b[0m\u001b[0m path = (known after apply)\r\n        }\r\n      \u001b[32m+\u001b[0m\u001b[0m external        = {\r\n          \u001b[32m+\u001b[0m\u001b[0m id   = (known after apply)\r\n          \u001b[32m+\u001b[0m\u001b[0m path = (known after apply)\r\n        }\r\n    }\r\n  \u001b[33m~\u001b[0m\u001b[0m oidc_client_secrets = (sensitive value)\r\n  \u001b[32m+\u001b[0m\u001b[0m organizations       = {\r\n      \u001b[32m+\u001b[0m\u001b[0m acme-inc        = {\r\n          \u001b[32m+\u001b[0m\u001b[0m domain = [\r\